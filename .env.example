# Created by `npx convex dev`.
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# Local auth callback URL. For production set this in Convex to your Vercel/custom domain.
# Example production value: https://yourbusinessapp.com
# Set with: npx convex env set SITE_URL https://yourbusinessapp.com
SITE_URL=http://localhost:3000

# Convex production environment variables generated by `npm run keys`.
# Set these in the Convex dashboard, not in Vercel.
JWT_PRIVATE_KEY=
JWKS=

# Transactional email. Set these in the Convex dashboard, not in browser-exposed Vercel vars.
# FROM_EMAIL should use a verified Resend domain, for example:
# Center Business Services <info@biz.center>
RESEND_API_KEY=
FROM_EMAIL=
APP_URL=http://localhost:3000

# OpenAI-powered CRM assistant. Set in the Convex dashboard.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
